# Build specifically for linux/arm64 platform
FROM --platform=linux/arm64 node:20-alpine3.19

# Install essential build tools and runtime support
RUN apk add --no-cache \
    g++ \
    make \
    py3-pip \
    supervisor \
    bash \
    caddy \
    dos2unix

# Install global npm packages
RUN npm --no-update-notifier --no-fund --global install pnpm@10.6.1 pm2

# Set working directory
WORKDIR /app

# Copy project files
COPY . /app

# Copy and configure system-level files
COPY var/docker/supervisord.conf /etc/supervisord.conf
COPY var/docker/Caddyfile /app/Caddyfile
COPY var/docker/entrypoint.sh /usr/local/bin/docker-entrypoint.sh
COPY var/docker/supervisord/caddy.conf /etc/supervisor.d/caddy.conf

# Normalize line endings and fix permissions for entrypoint
RUN dos2unix /usr/local/bin/docker-entrypoint.sh && chmod +x /usr/local/bin/docker-entrypoint.sh

# Install project dependencies
RUN pnpm install

# Build the app (can use NODE_OPTIONS if needed)
ENV NODE_OPTIONS="--max-old-space-size=8192"
RUN pnpm run build

# Expose necessary ports
EXPOSE 4200 3000 80

# Entrypoint script
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
